{
    "name": "khaledabdalbasit/launchpoint",
    "description": "Laravel Starter Kit for API with Global Exception & ApiResponse Trait",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "KhaledAbdalbasit\\LaunchPoint\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KhaledAbdalbasit\\LaunchPoint\\Providers\\LaunchPointServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
